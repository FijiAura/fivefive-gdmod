{
	"geode": "5.7.1",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "dominodev.fivefive",
	"name": "FIVE-FIVE",
	"version": "v1.1.1",
	"developers": ["dominodev", "Fijiaura"]
	"description": "funny kingsammelot number go brr",
	"dependencies": {
		"geode.node-ids": ">=v1.23.3",
		"prevter.imageplus": ">=v1.1.0"
	},

	"resources": {
		"files": [
			"resources/fivefive.mp3",
			"resources/fivefive.webp"
		]
	},

	"settings": {
		"onlyondeath":{
			"type": "bool",
			"default": false,
			"description": "If to only do the 55 if you die at 55%",
			"name": "Only On Death"
		},
		"number":{
			"type": "int",
			"default": 55,
			"description": "The funny number you want to show the video at",
			"name": "Funny Percentage"
		},

		"volume":{
			"type": "float",
			"default": 1.0,
			"max": 1.0,
			"min": 0,
			"control": {
				"arrows": true,
				"arrow-step": 0.1,
				"slider": true,
				"input": true
			},
			"name": "Volume"
		},

		"fullscreen":{
			"type": "bool",
			"default": false,
			"name": "Play Fullscreen",
			"description": "Whether or not to play the video in full screen."
		}
	},

	"tags": ["joke"],

	"links": {"source": "https://github.com/DominoKiddoo/fivefive-gdmod"}


}
